# Template for fam-keys.env — copy to `fam-keys.env` and fill in real keys.
#   cp fam-keys.env.example fam-keys.env
# Keys may be base64 (e.g. AbCd...==) or 0xhex. The script normalizes them.
# The real fam-keys.env is gitignored and must never be committed.
#
# Fam (channel 0) key — shared/reused across ALL fam nodes so they share the channel.
FAM_PSK_DEFAULT=""
# EDC-MeshOps (channel 1) key.
OPS_PSK_DEFAULT=""
